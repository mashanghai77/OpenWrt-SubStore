config substore 'config'
	option enabled '0'
	option frontend_port '3001'
	option frontend_host '::'
	option frontend_backend_path '/sub-store-api'
	option data_dir '/etc/sub-store'
	option backend_custom_name 'OpenWrt'
	option backend_custom_icon ''
	option backend_sync_cron ''
	option backend_upload_cron ''
	option backend_download_cron ''
	option produce_cron ''
	option push_service ''
	option cors_allowed_origins '*'
	option backend_default_proxy ''
	option max_header_size '32768'
	option body_json_limit '1mb'
	option x_powered_by ''
	option data_url ''
	option data_url_post ''

config http_meta 'http_meta'
	option enabled '0'
	option host '127.0.0.1'
	option port '9876'
	option authorization ''
	option max_available_port ''
	option min_available_port ''
	option disable_auto_clean '0'
	option temp_folder ''
	option body_json_limit '1mb'
	option meta_dir '/etc/sub-store/http-meta'
	option external_core_path ''
